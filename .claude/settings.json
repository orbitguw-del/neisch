{
  "permissions": {
    "allow": [
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Set-Location *)",
      "PowerShell(Get-Content *)",
      "PowerShell(dir *)",
      "mcp__computer-use__screenshot",
      "mcp__computer-use__wait",
      "mcp__computer-use__zoom",
      "mcp__Claude_in_Chrome__tabs_context_mcp",
      "mcp__Claude_in_Chrome__find",
      "mcp__Claude_in_Chrome__get_page_text",
      "mcp__Claude_in_Chrome__read_page",
      "mcp__Claude_in_Chrome__list_connected_browsers",
      "mcp__Claude_Preview__preview_screenshot",
      "mcp__Claude_Preview__preview_start",
      "mcp__Claude_Preview__preview_console_logs",
      "mcp__Claude_Preview__preview_snapshot",
      "mcp__Claude_Preview__preview_logs",
      "mcp__Claude_Preview__preview_list",
      "mcp__Claude_Preview__preview_network",
      "mcp__visualize__show_widget"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-C:/consne}\" 2>/dev/null; if [ -n \"$(git status --porcelain diary/ 2>/dev/null)\" ]; then git add diary/ && git commit -q -m \"diary: auto-commit entries at session start [hook]\" && (git push -q 2>/dev/null || true) && echo '{\"systemMessage\":\"Auto-committed uncommitted diary/ changes (session-start hook).\"}'; fi",
            "timeout": 30,
            "statusMessage": "Checking diary/ for uncommitted entries"
          }
        ]
      }
    ]
  }
}
