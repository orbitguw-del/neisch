<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name="com.storeyinfra.app.MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep-link handler for Supabase OAuth callbacks -->
            <!-- Catches: storeyapp://auth/callback?code=... -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="storeyapp" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- ── Permissions ─────────────────────────────────────────────────── -->

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Camera (added 2026-05-22 — was missing, app crashed when invoking camera) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Photo storage — split by Android version per Google's guidelines -->
    <!-- Android 12 and below: legacy external-storage read -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 13+: scoped media access -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Camera hardware is required but the feature is OPTIONAL so the app
         installs on tablets without a rear camera. -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- ── Package visibility (Android 11+) ──────────────────────────────
         Without this, ACTION_IMAGE_CAPTURE returns null on Android 11+ and
         the Capacitor camera plugin crashes. -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.PICK" />
            <data android:mimeType="image/*" />
        </intent>
    </queries>

</manifest>
